# Remplacez cette valeur par votre vrai Client ID PayPal
# Obtenez-le sur: https://developer.paypal.com/dashboard/applications
# Pour les tests: utilisez votre Client ID Sandbox
# Pour la production: utilisez votre Client ID Live
VITE_PAYPAL_CLIENT_ID=YOUR_PAYPAL_CLIENT_ID_HERE

# EmailJS — obtenez vos clés sur https://www.emailjs.com
VITE_EMAILJS_SERVICE_ID=YOUR_SERVICE_ID
VITE_EMAILJS_TEMPLATE_ID=YOUR_TEMPLATE_ID
VITE_EMAILJS_PUBLIC_KEY=YOUR_PUBLIC_KEY
